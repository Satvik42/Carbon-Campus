# =========================================================================
# Carbon Compass - Environment Variables Template
# =========================================================================
# This file lists the environment variables required for running and deploying
# Carbon Compass. Copy this file to '.env.local' for local development, or
# configure them in Google Secret Manager/Cloud Run for production.
# =========================================================================

# -------------------------------------------------------------------------
# 🔑 Core Secrets (REQUIRED at Runtime)
# -------------------------------------------------------------------------
# Your Gemini API Key from Google AI Studio. Used securely server-side only.
# Do NOT prefix with NEXT_PUBLIC_ to avoid exposing it to the browser.
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# ⚙️ Configurations (Optional)
# -------------------------------------------------------------------------
# The Google Gemini Model version to run. Defaults to 'gemini-2.5-flash'.
GEMINI_MODEL=gemini-2.5-flash

# Next.js Port and Hostname settings (Used in container/production deployment)
PORT=3000
HOSTNAME=0.0.0.0
